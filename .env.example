# .env.example
# Cryptocurrency Analytics Platform — Kiến trúc điều chỉnh
# Copy this file to .env and fill in your actual values before running.

# ─────────────────────────────────────────────
# Binance API
# ─────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─────────────────────────────────────────────
# Kafka (KRaft mode — no Zookeeper)
# ─────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─────────────────────────────────────────────
# Spark / Object Storage (MinIO/S3)
# ─────────────────────────────────────────────
SPARK_MASTER=spark://localhost:7077
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
DELTA_BASE_PATH=s3a://crypto-lake/lakehouse
SPARK_CHECKPOINT_BASE=s3a://crypto-lake/checkpoints

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGO_URI=mongodb://root:changeme@localhost:27017
MONGO_DB=crypto_analytics

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=alerts@crypto-analytics.io

# ─────────────────────────────────────────────
# Alert Engine API
# ─────────────────────────────────────────────
NOTIFICATION_SVC=http://localhost:8001
ALERT_API_PORT=8000

# ─────────────────────────────────────────────
# Kubernetes (k3s deployment)
# ─────────────────────────────────────────────
K8S_NAMESPACE=crypto-analytics
SPARK_K8S_IMAGE=crypto-analytics/spark:latest
CONTAINER_REGISTRY=your-registry.example.com
